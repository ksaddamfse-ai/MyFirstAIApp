{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "OpenRouter": {
    "BaseUrl": "https://openrouter.ai/api/v1",
    "ApiKey": "API-KEY",
    "ModelName": "openrouter/free",
    "Timeout": 60
  },
  "NvidiaNim": {
    "BaseUrl": "https://integrate.api.nvidia.com/v1",
    "ApiKey": "API-KEY",
    "ModelName": "meta/llama-3.1-405b-instruct",
    "Timeout": 60
  },
  "Ollama": {
    "BaseUrl": "http://localhost:11434",
    "ModelName": "llama3",
    "Timeout": 30
  },
  "Benchmark": {
    "ProviderKeys": ["OpenRouterOpenAI", "OpenRouterCustom", "Ollama", "NvidiaNimOpenAI"],
    "ProviderModels": {
      "OpenRouterOpenAI": "openrouter/free",
      "OpenRouterCustom": "openrouter/free",
      "Ollama": "llama3",
      "NvidiaNimOpenAI": "meta/llama-3.1-405b-instruct"
    }
  }
}
